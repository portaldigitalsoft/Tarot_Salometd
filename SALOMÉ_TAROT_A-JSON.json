ument.getElementById('qrcode');\n\n    if (contenedor.style.display === \"none\" || contenedor.style.display === \"\") {\n        // Abrir\n        contenedor.style.display = \"inline-block\";\n        btn.innerHTML = \"✖️ CERRAR QR\";\n        \n        if (!qrGenerado) {\n            new QRCode(qrDiv, {\n                text: window.location.href,\n                width: 180,\n                height: 180,\n                colorDark : \"#000000\",\n                colorLight : \"#ffffff\",\n                correctLevel : QRCode.CorrectLevel.H\n            });\n            qrGenerado = true;\n        }\n        contenedor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });\n    } else {\n        // Cerrar\n        contenedor.style.display = \"none\";\n        btn.innerHTML = \"🔲 MOSTRAR CÓDIGO QR\";\n    }\n}\n\nasync function compartirNativo() {\n    const compartirData = {\n        title: 'Mi Tarjeta Digital',\n        text: '¡Hola! Te comparto mi tarjeta de contacto digital. Puedes verla aquí:',\n        url: window.location.href\n    };\n\n    // Lógica para Celulares (Android/iOS)\n    if (navigator.share) {\n        try {\n            await navigator.share(compartirData);\n        } catch (err) {\n            console.log(\"Compartir cancelado\");\n        }\n    } \n    // Lógica para Computadoras (PC/Mac)\n    else {\n        // Copia el enlace al portapapeles y avisa al usuario\n        navigator.clipboard.writeText(window.location.href).then(() => {\n            alert(\"Enlace copiado al portapapeles. ¡Ya puedes pegarlo donde quieras!\");\n        }).catch(err => {\n            alert(\"Para compartir en PC, copia la URL de la barra de direcciones.\");\n        });\n    }\n}\n</script>\n",
